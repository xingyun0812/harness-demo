<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ========== 日志级别（支持环境变量覆盖） ========== -->
    <!-- 用法：java -jar app.jar -DLOG_LEVEL_APP=TRACE             -->
    <property name="LOG_LEVEL_APP" value="${LOG_LEVEL_APP:-DEBUG}"/>
    <property name="LOG_LEVEL_REPO" value="${LOG_LEVEL_REPO:-${LOG_LEVEL_APP:-DEBUG}}"/>
    <property name="LOG_LEVEL_ROOT" value="${LOG_LEVEL_ROOT:-INFO}"/>
    <property name="LOG_LEVEL_SPRING" value="${LOG_LEVEL_SPRING:-WARN}"/>
    <property name="LOG_LEVEL_MYBATIS" value="${LOG_LEVEL_MYBATIS:-WARN}"/>
    <property name="LOG_LEVEL_FLYWAY" value="${LOG_LEVEL_FLYWAY:-WARN}"/>

    <!-- ========== Appender：JSON 结构化日志（控制台） ========== -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- 保留 serviceName 字段用于日志平台聚合 -->
            <includeContext>false</includeContext>
            <customFields>{"service":"harness-demo"}</customFields>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <level>level</level>
                <logger>logger</logger>
                <thread>thread</thread>
                <message>message</message>
                <stackTrace>stack_trace</stackTrace>
                <mdc>mdc</mdc>
            </fieldNames>
        </encoder>
    </appender>

    <!-- Appender：控制台纯文本（开发环境友好） -->
    <appender name="TEXT_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- 默认环境（包括生产）使用 JSON；dev profile 使用纯文本 -->
    <springProfile name="!dev">
        <root level="${LOG_LEVEL_ROOT}">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="dev">
        <root level="${LOG_LEVEL_ROOT}">
            <appender-ref ref="TEXT_CONSOLE"/>
        </root>
    </springProfile>

    <!-- 应用日志 -->
    <logger name="com.example.harnessdemo" level="${LOG_LEVEL_APP}" additivity="false">
        <springProfile name="dev"><appender-ref ref="TEXT_CONSOLE"/></springProfile>
        <springProfile name="!dev"><appender-ref ref="JSON_CONSOLE"/></springProfile>
    </logger>

    <!-- SQL 日志（repository 层独立控制） -->
    <springProfile name="dev">
        <logger name="com.example.harnessdemo.repository" level="${LOG_LEVEL_REPO}" additivity="false">
            <appender-ref ref="TEXT_CONSOLE"/>
        </logger>
    </springProfile>

    <!-- 框架日志 -->
    <logger name="org.springframework" level="${LOG_LEVEL_SPRING}"/>
    <logger name="com.baomidou.mybatisplus" level="${LOG_LEVEL_MYBATIS}"/>
    <logger name="org.flywaydb" level="${LOG_LEVEL_FLYWAY}"/>
</configuration>