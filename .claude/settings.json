{
  "permissions": {
    "allow": [
      "Bash(mvn *)",
      "Bash(git *)",
      "Bash(java *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(chmod *)",
      "Bash(which *)",
      "Bash(type *)"
    ],
    "ask": [
      "Bash(curl *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/scripts/claude-pre-push-guard.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
